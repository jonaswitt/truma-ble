{
  "name": "@jonaswitt/truma-ble",
  "version": "1.0.0",
  "description": "TypeScript BLE client for Truma cooler monitoring and control",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "truma-ble": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "watch": "tsc --watch",
